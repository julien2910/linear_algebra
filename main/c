#include "vector.h"
#include "matrix.h"

int main() {
    // Создание векторов
    Vector *v1 = vector_create(3);
    vector_set(v1, 0, 1.0);
    vector_set(v1, 1, 2.0);
    vector_set(v1, 2, 3.0);
    
    Vector *v2 = vector_create(3);
    vector_set(v2, 0, 4.0);
    vector_set(v2, 1, 5.0);
    vector_set(v2, 2, 6.0);
    
    // Сложение векторов
    Vector *sum = vector_add(v1, v2);
    vector_print(sum);  // [5.00, 7.00, 9.00]
    
    // Скалярное произведение
    double dot = vector_dot(v1, v2);
    printf("Dot product: %.2f\n", dot);  // 32.00
    
    // Освобождение памяти
    vector_free(v1);
    vector_free(v2);
    vector_free(sum);
    
    return 0;
}
